# Gemini API Keys (Multiple keys for rotation)
# You can provide a single key, a comma-separated list, or multiple numbered variables
VITE_GEMINI_API_KEY=
VITE_GEMINI_KEYS=key1,key2,key3
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=

# DeepSeek API Keys (Optional fallback)
# Supports same formats as Gemini keys
VITE_DEEPSEEK_API_KEY=
VITE_DEEPSEEK_KEYS=
DEEPSEEK_API_KEY_1=

# OpenRouter API Keys (Optional, sk-or-v1-...)
VITE_OPENROUTER_API_KEY=
