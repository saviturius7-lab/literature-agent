# Supabase Configuration (Pre-configured)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Google Gemini API Keys
# You can add multiple keys for rotation and rate limit handling
# The system will automatically rotate through available keys
GEMINI_API_KEY=your-primary-gemini-api-key

# Optional: Add up to 20 keys for better rate limit handling
# GEMINI_API_KEY_1=your-first-key
# GEMINI_API_KEY_2=your-second-key
# GEMINI_API_KEY_3=your-third-key
# ... up to GEMINI_API_KEY_20

# Or use comma-separated list:
# GEMINI_API_KEYS=key1,key2,key3,key4,key5

# Note: Keys with "TODO" or "YOUR_" prefixes will be ignored
# The system automatically handles:
# - API key rotation
# - Rate limit detection and retry
# - Failed key blacklisting
# - Quota cooldown periods
