# API Keys - You have multiple "spaces" to add keys:

# 1. Comma-separated lists (e.g., key1,key2,key3)
GEMINI_API_KEYS=
DEEPSEEK_API_KEYS=
OPENROUTER_API_KEYS=

# 2. Individual numbered variables (up to _20 for each)
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
# ... up to GEMINI_API_KEY_20

DEEPSEEK_API_KEY_1=
DEEPSEEK_API_KEY_2=
# ... up to DEEPSEEK_API_KEY_20

OPENROUTER_API_KEY_1=
OPENROUTER_API_KEY_2=
# ... up to OPENROUTER_API_KEY_20

# 3. Single default variable
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
